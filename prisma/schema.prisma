generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Settings {
  id             Int      @id @default(1)
  monthlySalary  Float
  requiredHours  Float    @default(9)
  weeklyOff      String   @default("Sunday")
  currency       String   @default("$")
  hideSalary     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Attendance {
  id           Int      @id @default(autoincrement())
  date         DateTime
  inTime       String?
  outTime      String?
  status       String
  remarks      String?
  isAutoMarked Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([date])
}
